# EditorConfig: https://editorconfig.org
# Ayuda a mantener consistencia entre diferentes editores

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.{json,jsonc}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.{sh,bash}]
indent_size = 2

[*.{cpp,hpp,h}]
indent_size = 4

[CMakeLists.txt]
indent_size = 2

[Makefile]
indent_style = tab

[*.{py,pyi}]
indent_size = 4
max_line_length = 100

[*.ipynb]
indent_size = 2

